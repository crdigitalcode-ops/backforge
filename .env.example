DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backforge?schema=public"
# If you already have a local PostgreSQL on port 5432 with different credentials,
# update DATABASE_URL to match that instance or change the host/port to your container.
REDIS_URL="redis://localhost:6379"
# Generate a long random value, for example:
# openssl rand -base64 48
JWT_SECRET=""
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
ENABLE_GRAPHQL=false
LOG_LEVEL="info"
FEATURE_FLAGS='{"eventBusV1":true,"rolloutAutomation":true,"canaryDeployments":true,"auditEvents":true}'
VITE_FEATURE_FLAGS='{"newDashboard":true,"launchLandingPage":true,"docsCallout":true}'
METRICS_ENABLED=true
METRICS_PORT=9090
ENABLE_CLUSTER=false
CLUSTER_WORKERS=0
QUEUE_NAME="jobs"
QUEUE_CONCURRENCY=4
GLOBAL_RATE_LIMIT_MAX=100
GLOBAL_RATE_LIMIT_WINDOW_MINUTES=15
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="admin"
S3_SECRET_KEY="password"
S3_BUCKET="backforge-storage"
# Optional CSP allow-lists for future CDNs or external services.
# CSP_EXTRA_SCRIPT_SRC="https://cdn.example.com"
# CSP_EXTRA_STYLE_SRC="https://fonts.googleapis.com"
# CSP_EXTRA_IMG_SRC="https://images.example.com"
# CSP_EXTRA_CONNECT_SRC="https://api.example.com"
# CSP_EXTRA_FONT_SRC="https://fonts.gstatic.com"
# CSP_EXTRA_DEFAULT_SRC="https://cdn.example.com"

# Railway production notes:
# - Set NODE_ENV=production
# - Set APP_URL to your Railway public URL or custom domain
# - Leave PORT unset on Railway; the platform injects it automatically
# - REDIS_URL is optional; the app degrades gracefully when Redis is absent
